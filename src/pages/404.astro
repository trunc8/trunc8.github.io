---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found">
  <div class="py-20">
    <div class="mx-auto max-w-xl px-4 text-center">
      <img
        src="/img/instructuresaurus-404.png"
        alt="404 dinosaur"
        class="mx-auto w-48 mb-8"
      />
      <h1 class="text-4xl font-bold text-on-surface mb-4">Page Not Found</h1>
      <p class="text-on-surface-muted mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex justify-center gap-4">
        <a
          href="/"
          class="px-5 py-2.5 rounded-lg bg-brand text-white font-medium text-sm hover:bg-brand-hover hover:no-underline transition-colors"
        >
          Go Home
        </a>
        <a
          href="/projects"
          class="px-5 py-2.5 rounded-lg border border-border text-on-surface font-medium text-sm hover:bg-surface-alt hover:no-underline transition-colors"
        >
          View Projects
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
