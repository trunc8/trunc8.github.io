---
---
<button
  type="button"
  aria-label="Search"
  class="search-open-btn p-2 rounded-lg hover:bg-surface-alt transition-colors text-on-surface-muted"
>
  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
  </svg>
</button>

<div id="search-dialog" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="search-overlay"></div>
  <div class="relative mx-auto mt-20 max-w-xl px-4">
    <div class="rounded-xl bg-surface border border-border shadow-xl overflow-hidden">
      <div id="pagefind-container" class="p-4"></div>
    </div>
  </div>
</div>

<script is:inline>
  (function initSearch() {
    var buttons = document.querySelectorAll('.search-open-btn');
    var dialog = document.getElementById('search-dialog');
    var overlay = document.getElementById('search-overlay');
    var loaded = false;

    async function openSearch() {
      dialog.classList.remove('hidden');
      document.body.style.overflow = 'hidden';

      if (!loaded) {
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = '/pagefind/pagefind-ui.css';
        document.head.appendChild(link);

        var pagefindUI = await import('/pagefind/pagefind-ui.js');
        var container = document.getElementById('pagefind-container');
        new pagefindUI.PagefindUI({
          element: container,
          showSubResults: true,
          showImages: false,
        });
        loaded = true;
      }

      setTimeout(function() {
        var input = document.querySelector('.pagefind-ui__search-input');
        if (input) input.focus();
      }, 100);
    }

    function closeSearch() {
      dialog.classList.add('hidden');
      document.body.style.overflow = '';
    }

    buttons.forEach(function(btn) {
      btn.addEventListener('click', openSearch);
    });
    if (overlay) overlay.addEventListener('click', closeSearch);

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeSearch();
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (dialog.classList.contains('hidden')) {
          openSearch();
        } else {
          closeSearch();
        }
      }
    });
  })();
</script>
