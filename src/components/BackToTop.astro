---
<button
  id="back-to-top"
  aria-label="Back to top"
  class="fixed bottom-6 right-6 z-40 p-3 rounded-full bg-brand text-white shadow-lg opacity-0 pointer-events-none transition-opacity hover:bg-brand-hover"
>
  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
  </svg>
</button>

<script>
  function initBackToTop() {
    const btn = document.getElementById('back-to-top');

    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        btn!.classList.remove('opacity-0', 'pointer-events-none');
        btn!.classList.add('opacity-100', 'pointer-events-auto');
      } else {
        btn!.classList.add('opacity-0', 'pointer-events-none');
        btn!.classList.remove('opacity-100', 'pointer-events-auto');
      }
    });

    btn?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  initBackToTop();
  document.addEventListener('astro:after-swap', initBackToTop);
</script>
