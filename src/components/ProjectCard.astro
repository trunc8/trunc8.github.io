---
interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  slug: string;
  tags?: string[];
  date: string;
}

const { title, description, image, imageAlt, slug, tags = [], date } = Astro.props;
---

<a href={`/projects/${slug}`} class="group block rounded-xl border border-border bg-surface hover:shadow-lg transition-all hover:no-underline overflow-hidden">
  <div class="aspect-video overflow-hidden bg-surface-alt">
    <img
      src={image}
      alt={imageAlt}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      loading="lazy"
    />
  </div>
  <div class="p-4">
    <p class="text-xs text-on-surface-muted mb-1">{date}</p>
    <h3 class="font-semibold text-on-surface group-hover:text-brand transition-colors line-clamp-2">{title}</h3>
    <p class="mt-1 text-sm text-on-surface-muted line-clamp-2">{description}</p>
    {tags.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1">
        {tags.slice(0, 3).map((tag) => (
          <span class="text-xs px-2 py-0.5 rounded-full bg-surface-alt text-on-surface-muted">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>
