---
import BaseLayout from './BaseLayout.astro';
import CopyCode from '../components/CopyCode.astro';
import { formatDate, readingTime } from '../utils/helpers';
import '../styles/prose.css';

interface Props {
  title: string;
  pubDate: Date;
  description?: string;
  ogImage?: string;
  mathjax?: boolean;
  rawContent?: string;
}

const { title, pubDate, description, ogImage, mathjax = false, rawContent } = Astro.props;
---

<BaseLayout title={`${title} | Siddharth Saha`} description={description} ogImage={ogImage}>
  <article class="py-12">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <header class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-on-surface mb-2">{title}</h1>
        <div class="flex items-center gap-3 text-sm text-on-surface-muted">
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
          {rawContent && <span>&middot;</span>}
          {rawContent && <span>{readingTime(rawContent)}</span>}
        </div>
      </header>
      <div class="prose prose-lg max-w-none">
        <slot />
      </div>
    </div>
  </article>
  <CopyCode />
</BaseLayout>
