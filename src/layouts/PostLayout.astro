---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../utils/helpers';
import '../styles/prose.css';

interface Props {
  title: string;
  pubDate: Date;
  description?: string;
  ogImage?: string;
  mathjax?: boolean;
}

const { title, pubDate, description, ogImage, mathjax = false } = Astro.props;
---

<BaseLayout title={`${title} | Siddharth Saha`} description={description} ogImage={ogImage}>
  <article class="py-12">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <header class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-on-surface mb-2">{title}</h1>
        <time class="text-sm text-on-surface-muted" datetime={pubDate.toISOString()}>
          {formatDate(pubDate)}
        </time>
      </header>
      <div class="prose prose-lg max-w-none">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
